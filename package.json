{
  "name": "ow-assistant-extension",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:test": "tsc -b && vite build --mode test",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "npm run build:test && playwright test",
    "test:e2e:ui": "npm run build:test && playwright test --ui",
    "test:e2e:debug": "npm run build:test && playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.1.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/vscode": "^1.105.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^4.0.7",
    "@vscode/test-electron": "^2.5.2",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "happy-dom": "^20.0.10",
    "typescript": "~5.8.3",
    "vite": "^7.0.5",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.0.7"
  }
}
