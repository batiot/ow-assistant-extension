# OpenWebUI Assistant Extension - Environment Variables

# OpenWebUI Base URL for development
# Set this to your local or remote OpenWebUI instance
# Example: http://localhost:8080
# Example: https://your-openwebui.com
VITE_OPENWEBUI_BASE_URL=

# Note: For production builds, use DEFAULT_OPENWEBUI_BASE_URL instead
# Example: DEFAULT_OPENWEBUI_BASE_URL=https://production-openwebui.com npm run build
